{
  "name": "@spideru/ai-template",
  "version": "0.2.0",
  "description": "CLI to install and sync AI agent skills, architecture rules, and model guidance.",
  "license": "UNLICENSED",
  "bin": {
    "ai-template": "bin/ai-template.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    ".claude",
    ".codex",
    "bin",
    "meta",
    "src",
    "NEWS.md",
    "README.md"
  ],
  "scripts": {
    "check": "npm test && npm run pack:check:tmp",
    "test": "node --test",
    "pack:check": "npm pack --dry-run",
    "pack:check:tmp": "npm --cache /private/tmp/ai-template-npm-cache pack --dry-run",
    "prepublishOnly": "npm run check",
    "publish:current": "npm publish",
    "publish:patch": "npm version patch && npm publish",
    "publish:minor": "npm version minor && npm publish",
    "publish:major": "npm version major && npm publish"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "agents",
    "claude",
    "codex",
    "skills",
    "cli"
  ]
}
